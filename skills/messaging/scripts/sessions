#!/usr/bin/env bash
# ---
# name: sessions
# description: List currently-active kiln-lite agent sessions (peer lookup for messaging).
# usage: sessions <list|show|resolve> [args]
# ---
#
# Subcommands:
#   list               List all currently-active agent IDs and their session UUIDs.
#   show <agent-id>    Show session metadata for an agent (uuid, inbox path, unread count).
#   resolve <uuid>     Resolve a Pi session UUID to an agent ID.
#
# Active sessions are discovered via the `.id` files the kiln-lite extension
# writes to $AGENT_HOME/sessions/ at session_start and removes at session_shutdown.
# If sessions crash without cleanup, stale .id files can linger — use `sessions list`
# to see what's registered.
#
# Requires env: $AGENT_HOME, $AGENT_ID.

set -euo pipefail

: "${AGENT_HOME:?AGENT_HOME not set — is kiln-lite loaded?}"

SESSIONS_DIR="${AGENT_HOME}/sessions"
INBOX_ROOT="${AGENT_HOME}/inbox"

die() { echo "sessions: $*" >&2; exit 1; }

usage() {
	cat <<'EOF' >&2
Usage:
  sessions list                 list active agent IDs + their session UUIDs
  sessions show <agent-id>      show detail for one agent
  sessions resolve <uuid>       resolve a session UUID to an agent ID
EOF
	exit 1
}

# Count unread .md files in a given agent's inbox.
count_unread() {
	local agent="$1"
	local dir="${INBOX_ROOT}/${agent}"
	[ -d "$dir" ] || { echo 0; return; }
	local n=0
	for f in "$dir"/*.md; do
		[ -f "$f" ] && n=$((n + 1))
	done
	echo "$n"
}

cmd_list() {
	if [ ! -d "$SESSIONS_DIR" ]; then
		echo "(no active sessions)"
		return
	fi
	local found=0
	# Columnar: AGENT_ID  UUID  UNREAD [self]
	printf '%-28s  %-40s  %s\n' "AGENT_ID" "SESSION_UUID" "UNREAD"
	for f in "$SESSIONS_DIR"/*.id; do
		[ -f "$f" ] || continue
		local uuid agent unread marker
		uuid=$(basename "$f" .id)
		agent=$(cat "$f")
		unread=$(count_unread "$agent")
		marker=""
		[ "${AGENT_ID:-}" = "$agent" ] && marker=" [self]"
		printf '%-28s  %-40s  %s%s\n' "$agent" "$uuid" "$unread" "$marker"
		found=1
	done
	[ "$found" = 1 ] || echo "(no active sessions)"
}

cmd_show() {
	[ $# -ge 1 ] || die "show requires <agent-id>"
	local target="$1"
	local found=""
	if [ -d "$SESSIONS_DIR" ]; then
		for f in "$SESSIONS_DIR"/*.id; do
			[ -f "$f" ] || continue
			if [ "$(cat "$f")" = "$target" ]; then
				found=$(basename "$f" .id)
				break
			fi
		done
	fi
	if [ -z "$found" ]; then
		die "no active session with agent id: $target"
	fi
	local unread
	unread=$(count_unread "$target")
	cat <<EOF
agent_id:     $target
session_uuid: $found
inbox:        ${INBOX_ROOT}/${target}
unread:       $unread
EOF
}

cmd_resolve() {
	[ $# -ge 1 ] || die "resolve requires <uuid>"
	local uuid="$1"
	local path="${SESSIONS_DIR}/${uuid}.id"
	[ -f "$path" ] || die "no active session with uuid: $uuid"
	cat "$path"
}

main() {
	[ $# -ge 1 ] || usage
	local sub="$1"; shift
	case "$sub" in
		list) cmd_list "$@" ;;
		show) cmd_show "$@" ;;
		resolve) cmd_resolve "$@" ;;
		-h|--help|help) usage ;;
		*) die "unknown subcommand: $sub" ;;
	esac
}

main "$@"
