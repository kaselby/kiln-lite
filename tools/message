#!/usr/bin/env bash
# ---
# name: message
# description: Send/receive messages — DMs, channel pub/sub, and inbox management for inter-session coordination.
# arguments: "<send|publish|subscribe|unsubscribe|list-subscriptions|read|list|status> [args]"
# ---
#
# Subcommands:
#   send <to> <summary> [--body <text> | --stdin] [--priority normal|high]
#        Deliver a direct message to another agent session.
#   publish <channel> <summary> [--body <text> | --stdin] [--priority ...]
#        Publish a message to every subscriber of a channel.
#   subscribe <channel>
#   unsubscribe <channel>
#   list-subscriptions
#        List channels this session is subscribed to.
#   status
#        Show daemon status (pid, uptime, session count, channel count).
#
#   read <id-prefix> [--peek]
#        Print a received message and mark it read (moves it to .read/).
#        --peek leaves the message in the unread queue.
#   list [--unread|--all]
#        List received messages (reads files — no daemon).
#
# Requires env: $AGENT_HOME, $AGENT_ID, $INBOX.
#
# All channel/DM subcommands delegate to `kl-msg`, which talks to the
# kiln-lite daemon over its Unix socket and autostarts it if needed.
# `read` and `list` read files directly — they don't need the daemon.

set -euo pipefail

: "${AGENT_HOME:?AGENT_HOME not set — is kiln-lite loaded?}"
: "${AGENT_ID:?AGENT_ID not set — is kiln-lite loaded?}"
: "${INBOX:?INBOX not set — is kiln-lite loaded?}"

die() { echo "message: $*" >&2; exit 1; }

usage() {
	cat <<'EOF' >&2
Usage:
  message send <to> <summary> [--body <text> | --stdin] [--priority normal|high]
  message publish <channel> <summary> [--body <text> | --stdin] [--priority ...]
  message subscribe <channel>
  message unsubscribe <channel>
  message list-subscriptions
  message status

  message read <id-prefix> [--peek]
  message list [--unread|--all]
EOF
	exit 1
}

# --- daemon-bound subcommands (delegate to kl-msg) ---

require_kl_msg() {
	command -v kl-msg >/dev/null 2>&1 \
		|| die "kl-msg not found on PATH — did 'npm link' run? See install.sh."
}

# Translate message's --stdin flag to kl-msg's --body-stdin in-place.
# Writes to the caller-provided array variable name (nameref-free for
# bash 3.2 compat — no mapfile, no declare -n). Usage:
#   _translated=()
#   translate_stdin_flag "$@"
#   # use "${_translated[@]}"
# The indirection avoids subshells (which can't mutate caller state).
translate_stdin_flag() {
	_translated=()
	local a
	for a in "$@"; do
		if [ "$a" = "--stdin" ]; then
			_translated+=("--body-stdin")
		else
			_translated+=("$a")
		fi
	done
}

cmd_send() {
	require_kl_msg
	[ $# -ge 2 ] || die "send requires <to> <summary>"
	translate_stdin_flag "$@"
	exec kl-msg send ${_translated[@]+"${_translated[@]}"}
}

cmd_publish() {
	require_kl_msg
	[ $# -ge 2 ] || die "publish requires <channel> <summary>"
	translate_stdin_flag "$@"
	exec kl-msg publish ${_translated[@]+"${_translated[@]}"}
}

cmd_subscribe() {
	require_kl_msg
	[ $# -ge 1 ] || die "subscribe requires <channel>"
	exec kl-msg subscribe "$1"
}

cmd_unsubscribe() {
	require_kl_msg
	[ $# -ge 1 ] || die "unsubscribe requires <channel>"
	exec kl-msg unsubscribe "$1"
}

cmd_list_subscriptions() {
	require_kl_msg
	exec kl-msg list-subscriptions
}

cmd_status() {
	require_kl_msg
	exec kl-msg status
}

# --- file-based subcommands (no daemon needed) ---

cmd_list() {
	local mode="unread"
	case "${1:-}" in
		--unread) mode="unread" ;;
		--all) mode="all" ;;
		"" ) ;;
		*) die "unknown flag: ${1}" ;;
	esac

	local dir="$INBOX"
	local listed=0

	if [ "$mode" = "unread" ] || [ "$mode" = "all" ]; then
		if [ -d "$dir" ]; then
			for f in "$dir"/*.md; do
				[ -f "$f" ] || continue
				print_msg_entry "$f" "unread"
				listed=1
			done
		fi
	fi
	if [ "$mode" = "all" ]; then
		if [ -d "$dir/.read" ]; then
			for f in "$dir/.read"/*.md; do
				[ -f "$f" ] || continue
				print_msg_entry "$f" "read"
				listed=1
			done
		fi
	fi

	[ "$listed" = 1 ] || echo "(no messages)"
}

print_msg_entry() {
	local f="$1" status="$2"
	local id base from summary ts
	base=$(basename "$f" .md)
	id="$base"
	# Light frontmatter parsing — first block between --- markers.
	from=$(awk '/^---$/{n++; if(n==2) exit; next} n==1 && /^from:/{sub(/^from: */,""); print; exit}' "$f" || true)
	summary=$(awk '/^---$/{n++; if(n==2) exit; next} n==1 && /^summary:/{sub(/^summary: */,""); gsub(/^"|"$/, ""); print; exit}' "$f" || true)
	ts=$(awk '/^---$/{n++; if(n==2) exit; next} n==1 && /^timestamp:/{sub(/^timestamp: */,""); print; exit}' "$f" || true)
	printf '[%s] %s  %s  %s  — %s\n' "$status" "$id" "${from:-?}" "${ts:-?}" "${summary:-(no summary)}"
}

cmd_read() {
	local peek=0 prefix=""
	for arg in "$@"; do
		case "$arg" in
			--peek) peek=1 ;;
			-*) die "unknown flag for read: $arg" ;;
			*) [ -z "$prefix" ] && prefix="$arg" || die "read takes one id prefix" ;;
		esac
	done
	[ -n "$prefix" ] || die "read requires an id prefix"

	local dir="$INBOX"
	local match="" was_unread=0
	# Look in unread first, then .read/.
	if [ -d "$dir" ]; then
		for f in "$dir"/${prefix}*.md; do
			[ -f "$f" ] || continue
			match="$f"
			was_unread=1
			break
		done
	fi
	if [ -z "$match" ] && [ -d "$dir/.read" ]; then
		for f in "$dir/.read"/${prefix}*.md; do
			[ -f "$f" ] || continue
			match="$f"
			break
		done
	fi
	[ -n "$match" ] || die "no message matching: $prefix"
	cat "$match"

	# Default: consume unread (move to .read/). --peek leaves it alone.
	if [ "$was_unread" = 1 ] && [ "$peek" = 0 ]; then
		mkdir -p "$dir/.read"
		mv "$match" "$dir/.read/" || {
			echo "message: warning: could not move to .read/: $match" >&2
		}
	fi
}

main() {
	[ $# -ge 1 ] || usage
	local sub="$1"; shift
	case "$sub" in
		send) cmd_send "$@" ;;
		publish) cmd_publish "$@" ;;
		subscribe) cmd_subscribe "$@" ;;
		unsubscribe) cmd_unsubscribe "$@" ;;
		list-subscriptions) cmd_list_subscriptions ;;
		status) cmd_status ;;

		list) cmd_list "$@" ;;
		read) cmd_read "$@" ;;
		-h|--help|help) usage ;;
		*) die "unknown subcommand: $sub (try -h)" ;;
	esac
}

main "$@"
